@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">AI Chat</h1>
    <input type="text" id="actionText" maxlength="100" placeholder="Enter action text (max 100 chars)" class="form-control mb-2" style="max-width: 300px; margin: 0 auto;" />
    <button id="logActionBtn" class="btn btn-primary">Log an action</button>
    <div id="loading" style="display: none;">Loading...</div>
    <div id="result"></div>
</div>

@section Scripts {
    <script>
        document.getElementById('logActionBtn').addEventListener('click', async function() {
            const btn = this;
            const loading = document.getElementById('loading');
            const result = document.getElementById('result');
            const textInput = document.getElementById('actionText');
            const text = textInput.value.trim();

            if (!text) {
                result.textContent = 'Please enter some text.';
                return;
            }

            if (text.length > 100) {
                result.textContent = 'Text must be 100 characters or less.';
                return;
            }

            btn.disabled = true;
            loading.style.display = 'block';
            result.textContent = '';

            try {
                const response = await fetch('/Home/LogAction', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ text: text })
                });

                const data = await response.json();
                if (data.success) {
                    result.textContent = data.message;
                } else {
                    result.textContent = data.message;
                }
            } catch (error) {
                result.textContent = 'An error occurred.';
            } finally {
                btn.disabled = false;
                loading.style.display = 'none';
            }
        });
    </script>
}
